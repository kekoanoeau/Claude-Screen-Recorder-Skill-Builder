{
  "manifest_version": 3,
  "name": "Claude Screen Recorder Skill Builder",
  "version": "0.1.0",
  "description": "Record a browser workflow and turn it into a Claude Code Skill.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "offscreen",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Screen Recorder"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
